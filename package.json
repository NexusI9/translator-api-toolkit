{
	"name": "translator",
	"version": "1.0.0",
	"description": "Tool to translate json content via API",
	"main": "index.ts",
	"scripts": {
		"start": "tsx src/index.ts",
		"libre": "pipenv run libretranslate --load-only en,fr,zt --host 127.0.0.1 --port 5000",
		"example": "tsx src/index.ts -l --input=./example/small/en-US/ --output=./example/small/"
	},
	"author": "Nassim El Khantour",
	"license": "ISC",
	"devDependencies": {
		"@types/node": "^25.4.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"deepl-node": "^1.24.0",
		"dotenv": "^17.3.1"
	}
}
